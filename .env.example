# AIgnition — Environment Configuration
# ======================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env   (macOS/Linux)
#   copy .env.example .env  (Windows)
#
# .env is git-ignored. Never commit your actual keys.

# ---------------------------------------------------------------------------
# Groq API Key — OPTIONAL (enables LLM-powered AI Copilot)
# ---------------------------------------------------------------------------
# Without this key the system runs in rule-based fallback mode:
#   - all insights, risks, and recommendations still work from live data
#   - chat interface uses pre-computed templates instead of LLM reasoning
#
# Get a free key at: https://console.groq.com  (no credit card required)
# Model used:        llama-3.3-70b-versatile
GROQ_API_KEY=

# ---------------------------------------------------------------------------
# Demo mode — set to 1 to skip training on startup (requires pre-built artifacts)
# ---------------------------------------------------------------------------
DEMO_MODE=0

# ---------------------------------------------------------------------------
# Streamlit server port (default: 8501)
# ---------------------------------------------------------------------------
STREAMLIT_SERVER_PORT=8501
